---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
---

<Base
  title="ブログ — 新月配列"
  description="新月配列に関する技術記事、チュートリアル、アップデート情報をお届けします。"
>
  <div class="pt-28 pb-24 px-4 max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold text-white mb-2">ブログ</h1>
    <p class="text-slate-400 mb-10">新月配列の最新情報・技術記事</p>

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {allTags.map((tag) => (
          <span class="px-3 py-1 rounded-full bg-[var(--color-surface-2)] border border-white/10 text-xs text-slate-400">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <div class="space-y-6">
      {posts.map((post) => (
        <article class="rounded-xl border border-white/10 bg-[var(--color-surface-2)] p-6 hover:border-brand-500/30 transition-all duration-200 hover:-translate-y-0.5">
          <a href={`/blog/${post.id}`} class="block">
            <div class="flex flex-wrap gap-2 mb-2">
              {post.data.tags.map((tag) => (
                <span class="text-xs text-brand-400">#{tag}</span>
              ))}
            </div>
            <h2 class="text-xl font-bold text-white mb-2 hover:text-brand-300 transition-colors">
              {post.data.title}
            </h2>
            <p class="text-slate-400 text-sm mb-4">{post.data.description}</p>
            <time
              datetime={post.data.publishedAt.toISOString()}
              class="text-xs text-slate-600"
            >
              {post.data.publishedAt.toLocaleDateString("ja-JP", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </a>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-slate-500 text-center py-16">記事はまだありません。</p>
    )}
  </div>
</Base>
