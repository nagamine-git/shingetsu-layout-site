---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const postUrl = new URL(`/blog/${post.id}/`, Astro.site).toString();

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  ...(post.data.updatedAt ? { dateModified: post.data.updatedAt.toISOString() } : {}),
  url: postUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  author: {
    "@type": "Person",
    "@id": "https://shingetsu-layout.com/#author",
    name: "nagamine",
    url: "https://github.com/nagamine-git",
  },
  publisher: {
    "@type": "Person",
    "@id": "https://shingetsu-layout.com/#author",
    name: "nagamine",
  },
  inLanguage: "ja",
  keywords: post.data.tags.join(", "),
};
---

<style is:global>
  @plugin "@tailwindcss/typography";

  .prose {
    --tw-prose-body: #cbd5e1;
    --tw-prose-headings: #f1f5f9;
    --tw-prose-lead: #94a3b8;
    --tw-prose-links: #8fa3ff;
    --tw-prose-bold: #f1f5f9;
    --tw-prose-counters: #94a3b8;
    --tw-prose-bullets: #475569;
    --tw-prose-hr: #1e293b;
    --tw-prose-quotes: #f1f5f9;
    --tw-prose-quote-borders: #334155;
    --tw-prose-captions: #64748b;
    --tw-prose-code: #86efac;
    --tw-prose-pre-code: #e2e8f0;
    --tw-prose-pre-bg: #1e293b;
    --tw-prose-th-borders: #334155;
    --tw-prose-td-borders: #1e293b;
    font-size: 1.0625rem;
    line-height: 1.9;
  }
  .prose h2 {
    margin-top: 2.5em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid #1e293b;
  }
  .prose h3 { margin-top: 2em; }
  .prose p { letter-spacing: 0.01em; }
  .prose table { font-size: 0.9em; }
  .prose th { background-color: #1e293b; }
</style>

<Base title={`${post.data.title} — 新月配列`} description={post.data.description}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={post.data.publishedAt.toISOString()} />
    {post.data.updatedAt && (
      <meta property="article:modified_time" content={post.data.updatedAt.toISOString()} />
    )}
    {post.data.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />
  </Fragment>

  <article class="pt-28 pb-24 px-4 max-w-3xl mx-auto">
    <header class="mb-10">
      <div class="flex flex-wrap gap-2 mb-4">
        {post.data.tags.map((tag) => (
          <a
            href={`/blog?tag=${encodeURIComponent(tag)}`}
            class="text-xs text-brand-400 px-2 py-1 rounded-full bg-brand-500/10 border border-brand-500/20 hover:bg-brand-500/20 hover:border-brand-500/40 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        {post.data.title}
      </h1>
      <p class="text-slate-400 mb-4">{post.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-slate-500">
        <time datetime={post.data.publishedAt.toISOString()}>
          公開: {post.data.publishedAt.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        {post.data.updatedAt && (
          <time datetime={post.data.updatedAt.toISOString()}>
            更新: {post.data.updatedAt.toLocaleDateString("ja-JP", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        )}
      </div>
    </header>

    <div class="prose prose-invert prose-slate max-w-none prose-headings:font-bold prose-a:text-brand-400 prose-code:text-green-300 prose-pre:bg-[var(--color-surface)] prose-pre:border prose-pre:border-white/10 prose-pre:overflow-x-auto [&_pre]:max-w-full">
      <Content />
    </div>

    <div class="mt-12 pt-8 border-t border-white/10">
      <a href="/blog" class="text-sm text-brand-400 hover:text-brand-300 transition-colors">
        ← ブログ一覧に戻る
      </a>
    </div>
  </article>
</Base>
