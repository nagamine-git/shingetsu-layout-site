---
import Base from "../layouts/Base.astro";

const TURNSTILE_SITE_KEY = import.meta.env.TURNSTILE_SITE_KEY ?? "1x00000000000000000000AA";
---

<Base
  title="お問い合わせ — 新月配列"
  description="新月配列に関するご質問・ご意見はこちらからお送りください。"
>
  <div class="pt-28 pb-24 px-4 max-w-xl mx-auto">
    <h1 class="text-4xl font-bold text-white mb-2">お問い合わせ</h1>
    <p class="text-slate-400 mb-10">
      ご質問・ご意見・不具合報告などはこちらからどうぞ。通常 2〜3 営業日以内にご返信します。
    </p>

    <div class="rounded-2xl border border-white/10 bg-[var(--color-surface-2)] p-8">
      <form id="contact-form" novalidate class="space-y-5">
        <div>
          <label for="name" class="block text-sm text-slate-400 mb-1">
            お名前 <span class="text-red-400">*</span>
          </label>
          <input
            id="name"
            type="text"
            name="name"
            required
            maxlength="100"
            placeholder="山田 太郎"
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-surface)] border border-white/10 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand-500 transition-colors"
          />
        </div>

        <div>
          <label for="email" class="block text-sm text-slate-400 mb-1">
            メールアドレス <span class="text-red-400">*</span>
          </label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-surface)] border border-white/10 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand-500 transition-colors"
          />
        </div>

        <div>
          <label for="message" class="block text-sm text-slate-400 mb-1">
            メッセージ <span class="text-red-400">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            minlength="1"
            maxlength="5000"
            rows="6"
            placeholder="ご質問・ご意見をお書きください"
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-surface)] border border-white/10 text-white placeholder:text-slate-600 focus:outline-none focus:border-brand-500 transition-colors resize-y"
          ></textarea>
        </div>

        <div
          class="cf-turnstile"
          data-sitekey={TURNSTILE_SITE_KEY}
          data-theme="dark"
          data-callback="onContactTurnstileSuccess"
          data-error-callback="onContactTurnstileError"
        ></div>

        <button
          id="contact-btn"
          type="submit"
          disabled
          class="w-full py-3 rounded-lg bg-brand-600 hover:bg-brand-500 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold transition-all duration-200"
        >
          送信する
        </button>

        <p id="contact-msg" class="text-sm hidden"></p>
      </form>
    </div>
  </div>
</Base>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  let turnstileToken = "";

  (window as Record<string, unknown>)["onContactTurnstileSuccess"] = (token: string) => {
    turnstileToken = token;
    const btn = document.getElementById("contact-btn") as HTMLButtonElement | null;
    if (btn) btn.disabled = false;
  };

  (window as Record<string, unknown>)["onContactTurnstileError"] = () => {
    turnstileToken = "";
    const btn = document.getElementById("contact-btn") as HTMLButtonElement | null;
    if (btn) btn.disabled = true;
  };

  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const msg = document.getElementById("contact-msg") as HTMLElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !msg) return;

    const nameEl = form.querySelector<HTMLInputElement>("#name");
    const emailEl = form.querySelector<HTMLInputElement>("#email");
    const messageEl = form.querySelector<HTMLTextAreaElement>("#message");
    const btn = form.querySelector<HTMLButtonElement>("#contact-btn");

    if (!nameEl || !emailEl || !messageEl || !btn) return;

    btn.disabled = true;
    btn.textContent = "送信中…";

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: nameEl.value,
          email: emailEl.value,
          message: messageEl.value,
          turnstileToken,
        }),
      });

      if (res.ok) {
        msg.textContent = "お問い合わせを受け付けました。2〜3 営業日以内にご返信します。";
        msg.className = "text-sm text-green-400";
        form.reset();
        turnstileToken = "";
      } else {
        const data = (await res.json()) as { error?: string };
        msg.textContent = data.error === "verification_failed"
          ? "認証に失敗しました。ページを再読み込みしてお試しください。"
          : "エラーが発生しました。しばらくしてからお試しください。";
        msg.className = "text-sm text-red-400";
      }
    } catch {
      msg.textContent = "通信エラーが発生しました。";
      msg.className = "text-sm text-red-400";
    }

    msg.classList.remove("hidden");
    btn.textContent = "送信する";
  });
</script>
