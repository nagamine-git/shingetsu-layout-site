---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import LayerDemo from "../components/LayerDemo.astro";
import GetStarted from "../components/GetStarted.astro";
import Faq from "../components/Faq.astro";
import Subscribe from "../components/Subscribe.astro";
import ShareButtons from "../components/ShareButtons.astro";

const softwareJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "新月配列",
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "macOS, Windows, Linux",
  description:
    "JIS かなの 46 文字を 30 キーに収め、ホームポジションから指を離さず高速に日本語を入力できるキーボード配列。",
  url: "https://shingetsu-layout.com",
  inLanguage: "ja",
  offers: { "@type": "Offer", price: "0", priceCurrency: "JPY" },
  author: {
    "@type": "Person",
    "@id": "https://shingetsu-layout.com/#author",
    name: "nagamine",
    url: "https://github.com/nagamine-git",
  },
};
---

<Base
  title="新月配列 — 最小かつ最高効率のPCキーボード用かな配列"
  description="新月配列は、JIS かなの 46 文字を 30 キーに収め、ホームポジションから指を離さず高速に日本語を入力できる革新的な配列です。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
  </Fragment>

  <Hero />
  <Features />
  <LayerDemo />
  <GetStarted />
  <Faq />
  <Subscribe />
  <div class="max-w-xl mx-auto px-4 pb-24">
    <ShareButtons loc="home" />
  </div>
</Base>
