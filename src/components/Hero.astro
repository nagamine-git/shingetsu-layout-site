---
---

<section class="relative min-h-screen flex flex-col items-center justify-center pt-14 px-4 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-950 via-[var(--color-surface)] to-[var(--color-surface)]" aria-hidden="true"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-600/10 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="relative z-10 text-center max-w-3xl mx-auto">
    <div class="inline-block mb-6 px-3 py-1 rounded-full border border-brand-500/40 bg-brand-500/10 text-brand-300 text-xs font-medium tracking-widest uppercase">
      日本語 かな配列
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6 text-white">
      最小かつ<br class="sm:hidden" />最高効率の<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-cyan-400">
        PCキーボード用<br class="sm:hidden" />かな配列
      </span>
    </h1>

    <p class="text-lg sm:text-xl text-slate-300 mb-10 max-w-xl mx-auto">
      新月配列は、JIS かなと同等の 46 文字を<strong class="text-white">わずか 30 キー</strong>に収め、
      ホームポジションから指を離さず高速に日本語を入力できる革新的な配列です。
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#get-started"
        class="px-8 py-3 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-semibold transition-all duration-200 shadow-lg shadow-brand-900/50 hover:shadow-brand-700/50 hover:-translate-y-0.5"
      >
        今すぐ導入する
      </a>
      <a
        href="#layer-demo"
        class="px-8 py-3 rounded-lg border border-white/20 hover:border-white/40 text-white font-semibold transition-all duration-200 hover:-translate-y-0.5"
      >
        配列を見る
      </a>
    </div>
  </div>

  <!-- SVG keyboard illustration -->
  <div class="relative z-10 mt-16 w-full max-w-2xl mx-auto opacity-60" aria-hidden="true">
    <svg viewBox="0 0 600 160" xmlns="http://www.w3.org/2000/svg" class="w-full drop-shadow-2xl">
      <!-- Row 0 -->
      {Array.from({length: 10}, (_, i) => (
        <g key={i} transform={`translate(${i * 58 + 4}, 4)`}>
          <rect width="52" height="44" rx="6" fill="#1e293b" stroke="#334155" stroke-width="1"/>
          <text x="26" y="28" text-anchor="middle" fill="#94a3b8" font-size="16" font-family="serif">
            {['た','て','い','す','か','ん','な','に','ら','せ'][i]}
          </text>
        </g>
      ))}
      <!-- Row 1 -->
      {Array.from({length: 10}, (_, i) => (
        <g key={i} transform={`translate(${i * 58 + 20}, 56)`}>
          <rect width="52" height="44" rx="6" fill={i >= 3 && i <= 6 ? '#1e3a5f' : '#1e293b'} stroke={i >= 3 && i <= 6 ? '#3b82f6' : '#334155'} stroke-width="1"/>
          <text x="26" y="28" text-anchor="middle" fill={i >= 3 && i <= 6 ? '#93c5fd' : '#94a3b8'} font-size="16" font-family="serif">
            {['ち','と','し','は','き','く','の','り','れ','つ'][i]}
          </text>
        </g>
      ))}
      <!-- Row 2 -->
      {Array.from({length: 10}, (_, i) => (
        <g key={i} transform={`translate(${i * 58 + 36}, 108)`}>
          <rect width="52" height="44" rx="6" fill="#1e293b" stroke="#334155" stroke-width="1"/>
          <text x="26" y="28" text-anchor="middle" fill="#94a3b8" font-size="16" font-family="serif">
            {['さ','そ','ひ','ふ','こ','ま','も','ね','ろ','わ'][i]}
          </text>
        </g>
      ))}
    </svg>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-500 text-xs animate-bounce">
    <span>スクロール</span>
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
      <path d="M8 12L2 6h12z"/>
    </svg>
  </div>
</section>
