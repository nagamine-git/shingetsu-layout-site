---
const qwerty = [
  ["q","w","e","r","t","y","u","i","o","p"],
  ["a","s","d","f","g","h","j","k","l",";"],
  ["z","x","c","v","b","n","m",",",".","/"],
];
const kana = [
  ["た","て","い","す","か","ん","な","に","ら","せ"],
  ["ち","と","し","は","き","く","の","り","れ","つ"],
  ["さ","そ","ひ","ふ","こ","ま","も","ね","ろ","わ"],
];
const homeRowCols = [3, 4, 5, 6];
---

<section class="relative min-h-screen flex flex-col items-center justify-center pt-14 px-4 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-950 via-[var(--color-surface)] to-[var(--color-surface)]" aria-hidden="true"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-600/10 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="relative z-10 text-center max-w-3xl mx-auto">
    <div class="inline-block mb-6 px-3 py-1 rounded-full border border-brand-500/40 bg-brand-500/10 text-brand-300 text-xs font-medium tracking-widest uppercase">
      日本語 かな配列
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6 text-white">
      最小かつ<br class="sm:hidden" />最高効率の<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-cyan-400">
        PCキーボード用<br class="sm:hidden" />かな配列
      </span>
    </h1>

    <p class="text-lg sm:text-xl text-slate-300 mb-10 max-w-xl mx-auto">
      新月配列は、主要なかな文字を<strong class="text-white">30 キー</strong>に収め、
      ホームポジションを崩さずに日本語を入力できるかな配列です。
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#get-started"
        class="px-8 py-3 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-semibold transition-all duration-200 shadow-lg shadow-brand-900/50 hover:shadow-brand-700/50 hover:-translate-y-0.5"
      >
        今すぐ導入する
      </a>
      <a
        href="#layer-demo"
        class="px-8 py-3 rounded-lg border border-white/20 hover:border-white/40 text-white font-semibold transition-all duration-200 hover:-translate-y-0.5"
      >
        配列を見る
      </a>
    </div>
  </div>

  <!--
    SVG keyboard illustration: dual-legend per key
    Upper legend = Layer 1 (かな), lower-right = Layer 0 (QWERTY)
    viewBox: 3 rows × (56px tall, 62px pitch) + row offsets (0/20/40px)
    Max x = 9×62 + 52 + 40 = 650  Max y = 132 + 60 = 192
  -->
  <div class="relative z-10 mt-14 w-full max-w-2xl mx-auto" aria-hidden="true">
    <svg
      viewBox="0 0 650 196"
      xmlns="http://www.w3.org/2000/svg"
      class="w-full drop-shadow-2xl opacity-80"
      role="img"
      aria-label="新月配列キーボード図（上段：かな、右下：QWERTY）"
    >
      {qwerty.map((row, rowIdx) =>
        row.map((q, colIdx) => {
          const offsetX = rowIdx * 20;
          const x = colIdx * 62 + offsetX + 4;
          const y = rowIdx * 68 + 4;
          const isHome = rowIdx === 1 && homeRowCols.includes(colIdx);
          const bgFill = isHome ? "#1e3a5f" : "#1e293b";
          const strokeCol = isHome ? "#3b82f6" : "#334155";
          const kanaColor = isHome ? "#93c5fd" : "#cbd5e1";
          return (
            <g key={`${rowIdx}-${colIdx}`}>
              <rect x={x} y={y} width="56" height="60" rx="7"
                fill={bgFill} stroke={strokeCol} stroke-width={isHome ? "1.5" : "1"} />
              {/* kana — center, large */}
              <text x={x + 28} y={y + 32} text-anchor="middle"
                fill={kanaColor} font-size="19" font-family="'Noto Sans JP', serif" font-weight="500">
                {kana[rowIdx]?.[colIdx]}
              </text>
              {/* QWERTY — bottom-right, small */}
              <text x={x + 50} y={y + 54} text-anchor="end"
                fill="#475569" font-size="10" font-family="ui-monospace, monospace">
                {q}
              </text>
            </g>
          );
        })
      )}
    </svg>
    <p class="text-center text-xs text-slate-600 mt-2">
      大：かな（Layer 1）　右下小：QWERTY（Layer 0）　青：ホームポジション
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-slate-600 text-xs animate-bounce">
    <span>スクロール</span>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
      <path d="M8 12L2 6h12z"/>
    </svg>
  </div>
</section>
