---
const steps = {
  macos: [
    {
      num: 1,
      title: "Karabiner-Elements をインストール",
      code: "brew install --cask karabiner-elements",
      note: "Homebrew が必要です。",
    },
    {
      num: 2,
      title: "設定ファイルをダウンロード",
      code: 'curl -L https://raw.githubusercontent.com/nagamine-git/shingetsu-layout/main/karabiner/shingetsu.json \\\n  -o ~/.config/karabiner/assets/complex_modifications/shingetsu.json',
      note: null,
    },
    {
      num: 3,
      title: "Karabiner-Elements で有効化",
      code: null,
      note: 'Complex Modifications → "Add predefined rule" → "新月配列" を有効にする',
    },
  ],
  windows: [
    {
      num: 1,
      title: "hazkey をインストール",
      code: "winget install hazkey",
      note: "Windows 10 / 11 対応",
    },
    {
      num: 2,
      title: "設定を適用",
      code: null,
      note: "hazkey の設定画面から「新月配列」を選択して適用します。",
    },
  ],
  linux: [
    {
      num: 1,
      title: "hazkey をビルド",
      code: "git clone https://github.com/nagamine-git/hazkey\ncd hazkey && make install",
      note: "libxkbcommon が必要です。",
    },
    {
      num: 2,
      title: "XKB レイアウトを設定",
      code: 'setxkbmap -option "shingetsu"',
      note: null,
    },
  ],
};
---

<section id="get-started" class="py-24 px-4 bg-[var(--color-surface-2)]/40">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">導入方法</h2>
      <p class="text-slate-400 max-w-xl mx-auto">
        macOS・Windows・Linux すべてに対応。数ステップで今日から使い始められます。
      </p>
    </div>

    <!-- OS tabs -->
    <div class="flex justify-center gap-2 mb-8" id="os-tabs" role="tablist">
      <button class="os-tab-btn active px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200 bg-brand-600 text-white border border-brand-500" data-os="macos" role="tab" aria-selected="true">
        macOS
      </button>
      <button class="os-tab-btn px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200 border border-white/10 text-slate-400 hover:text-white" data-os="windows" role="tab" aria-selected="false">
        Windows
      </button>
      <button class="os-tab-btn px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200 border border-white/10 text-slate-400 hover:text-white" data-os="linux" role="tab" aria-selected="false">
        Linux
      </button>
    </div>

    <!-- Steps panels -->
    {Object.entries(steps).map(([os, stepsArr]) => (
      <div class="os-panel space-y-4" data-os={os} style={os !== "macos" ? "display:none" : ""}>
        {stepsArr.map((step) => (
          <div class="rounded-xl border border-white/10 bg-[var(--color-surface-2)] p-5">
            <div class="flex items-start gap-4">
              <span class="shrink-0 w-7 h-7 rounded-full bg-brand-600 text-white text-xs font-bold flex items-center justify-center">
                {step.num}
              </span>
              <div class="flex-1">
                <h3 class="font-semibold text-white mb-2">{step.title}</h3>
                {step.code && (
                  <pre class="bg-[var(--color-surface)] rounded-lg p-3 text-xs text-green-300 overflow-x-auto font-mono leading-relaxed">
                    <code>{step.code}</code>
                  </pre>
                )}
                {step.note && (
                  <p class="text-sm text-slate-400 mt-2">{step.note}</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    ))}

    <div class="text-center mt-8">
      <a
        href="https://github.com/nagamine-git/shingetsu-layout"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-brand-400 hover:text-brand-300 underline transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        GitHub でソースを見る
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>(".os-tab-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const os = btn.dataset.os;

      document.querySelectorAll<HTMLButtonElement>(".os-tab-btn").forEach((b) => {
        const isActive = b.dataset.os === os;
        b.setAttribute("aria-selected", String(isActive));
        if (isActive) {
          b.classList.add("bg-brand-600", "text-white", "border-brand-500");
          b.classList.remove("text-slate-400", "border-white/10");
        } else {
          b.classList.remove("bg-brand-600", "text-white", "border-brand-500");
          b.classList.add("text-slate-400", "border-white/10");
        }
      });

      document.querySelectorAll<HTMLElement>(".os-panel").forEach((panel) => {
        panel.style.display = panel.dataset.os === os ? "" : "none";
      });
    });
  });
</script>
