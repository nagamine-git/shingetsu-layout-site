---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const {
  title,
  description,
  ogImage = "/og-default.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[var(--color-surface)]/80 border-b border-white/10">
      <nav class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between">
        <a href="/" class="font-bold text-lg tracking-tight text-white">
          新月配列
        </a>
        <div class="flex items-center gap-6 text-sm">
          <a href="/#features" class="text-slate-400 hover:text-white transition-colors">特徴</a>
          <a href="/#get-started" class="text-slate-400 hover:text-white transition-colors">導入方法</a>
          <a href="/blog" class="text-slate-400 hover:text-white transition-colors">ブログ</a>
          <a href="/contact" class="text-slate-400 hover:text-white transition-colors">お問い合わせ</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-white/10 mt-24 py-8 text-center text-sm text-slate-500">
      <div class="max-w-5xl mx-auto px-4">
        <p>
          &copy; 2026 新月配列 &mdash;
          <a
            href="https://github.com/nagamine-git/shingetsu-layout"
            target="_blank"
            rel="noopener noreferrer"
            class="underline hover:text-white transition-colors"
          >
            GitHub
          </a>
        </p>
      </div>
    </footer>
  </body>
</html>
